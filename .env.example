# Aura OS Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# LLM Provider API Keys (choose at least one)
# OpenRouter (recommended - supports multiple models)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenAI (alternative provider)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Custom LLM Configuration
# LLM_PROVIDER=openrouter  # Default: openrouter
# LLM_MODEL=anthropic/claude-sonnet-4-20250514  # Default varies by provider

# Optional: Development Settings
# AURA_RELEASE=1  # Set to 1 when building release gem (default: development build with timestamp)
# AURA_SESSION_NAME=default  # Default session name

# Optional: Sandbox Configuration
# AURA_SANDBOX_ENABLED=1  # Enable sandbox mode (default: disabled)
