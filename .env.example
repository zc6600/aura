# Aura OS Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# LLM Provider API Keys (choose at least one)
# OpenRouter (recommended - supports multiple models)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenAI (alternative provider)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (alternative provider)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Gemini (alternative provider)
GEMINI_API_KEY=your_gemini_api_key_here

# DeepSeek (alternative provider)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Optional: Custom LLM Configuration
# LLM_PROVIDER=openrouter  # Default: openrouter
# LLM_MODEL=openai/gpt-4o  # Default varies by provider

# Optional: Integration Test Settings
# RUN_REAL_AGENTIC_TESTS=1  # Set to 1 to enable live integration tests

# Optional: Development Settings
# AURA_SESSION_NAME=default  # Default session name

# Optional: Sandbox Configuration
# AURA_SANDBOX_ENABLED=1  # Enable sandbox mode (default: disabled)
