{
  "name": "write_file",
  "description": "Write text content to a file within allowed directories.",
  "runtime": "python3",
  "entry": "logic.py",
  "test": "test.py",
  "permissions": {
    "file_system": "read-write",
    "self_edit": false
  },
  "input_schema": {
    "type": "object",
    "properties": {
      "file_path": { "type": "string" },
      "content": { "type": "string" },
      "context_permissions": { "type": "array" },
      "forbidden_extensions": { "type": "array" },
      "read_only_directories": { "type": "array" }
    },
    "required": ["file_path", "content"]
  }
}

