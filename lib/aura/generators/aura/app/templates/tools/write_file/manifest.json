{
  "name": "write_file",
  "description": "Write text content to a file within allowed directories.",
  "runtime": "python3",
  "entry": "logic.py",
  "test": "test.py",
  "permissions": {
    "file_system": "read-write",
    "self_edit": false
  },
  "input_schema": {
    "type": "object",
    "properties": {
      "file_path": { "type": "string", "description": "Workspace-relative file path" },
      "content": { "type": "string", "description": "File content to write" },
      "context_permissions": { "type": "array", "description": "Allowed path prefixes" },
      "forbidden_extensions": { "type": "array", "description": "Disallowed file extensions" },
      "read_only_directories": { "type": "array", "description": "Directories that must remain read-only" }
    },
    "required": [
      "file_path",
      "content"
    ]
  },
  "attach_output_to_summary": false
}
