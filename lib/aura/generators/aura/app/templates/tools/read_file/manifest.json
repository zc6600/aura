{
    "name": "read_file",
    "description": "Read text files within allowed paths. Use hints for large files.",
    "runtime": "python3",
    "entry": "logic.py",
    "test": "test.py",
    "dependencies": {
        "pip": []
    },
    "permissions": {
        "file_system": "read-only",
        "self_edit": false
    },
    "input_schema": {
        "type": "object",
        "properties": {
            "file_path": {
                "type": "string",
                "description": "Workspace-relative file path"
            },
            "context_permissions": {
                "type": "array",
                "description": "Allowed path prefixes"
            }
        },
        "required": [
            "file_path"
        ]
    },
    "attach_output_to_summary": false
}
