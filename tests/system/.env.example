# Copy this file to tests/system/.env for local real-LLM system tests.
# Never commit tests/system/.env or real API keys.

RUN_SYSTEM_TESTS=1

# Option A: let the harness auto-detect a provider from a standard key.
# OPENROUTER_API_KEY=sk-or-...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=sk-...
# GEMINI_API_KEY=...

# Option B: explicitly choose the provider and key env var.
# AURA_SYSTEM_LLM_PROVIDER=openrouter
# AURA_SYSTEM_LLM_API_KEY_ENV=OPENROUTER_API_KEY
# AURA_SYSTEM_LLM_MODEL=openai/gpt-4o-mini
# AURA_SYSTEM_LLM_API_BASE=

# Keep system tests cheap and deterministic.
AURA_SYSTEM_LLM_TEMPERATURE=0
AURA_SYSTEM_LLM_MAX_TOKENS=1024
AURA_SYSTEM_LLM_MAX_RETRIES=0
AURA_SYSTEM_MAX_STEPS=4
