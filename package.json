{
  "name": "aura-cli",
  "version": "0.1.0",
  "description": "AI-native operating system for folder-as-workspace agents.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "aura": "./dist/bin/aura.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/bin/aura.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "keywords": [
    "ai",
    "agent",
    "cli",
    "mcp",
    "workspace",
    "vcs"
  ],
  "author": "Chen Zhu",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "better-sqlite3": "^11.8.0",
    "clipanion": "^4.0.0-rc.4",
    "commander": "^12.0.0",
    "dotenv": "^16.4.5",
    "execa": "^8.0.1",
    "fast-glob": "^3.3.3",
    "node-pty": "^1.1.0",
    "picocolors": "^1.0.0",
    "yaml": "^2.4.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^20.11.24",
    "@vitest/coverage-v8": "^1.3.1",
    "tsup": "^8.0.2",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
